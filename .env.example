# העתק קובץ זה ל-.env (או הגדר את המשתנים ישירות בפלטפורמת האירוח, למשל Render)
# ואל תעלה .env אמיתי לגיט - הוא כבר מוגדר ב-.gitignore

# מפתח ה-API שהאתר (WEB) מצפה לו ב-/api/import/post
API_SECRET_KEY=your_new_secret_key_here

# רשימת יעדים מופרדת בפסיקים (בלי רווחים מיותרים)
TARGET_URLS=https://new0040005.duckdns.org/api/import/post,https://new0040000.duckdns.org/api/import/post,https://my-channel-w1nx.onrender.com/api/import/post

# ערוץ "פינת תורה" - נפרד לגמרי מהיעדים למעלה
TORAH_CHANNEL_URL=https://entertainment-channel.onrender.com/api/import/post
TORAH_API_KEY=your_new_torah_channel_key_here
